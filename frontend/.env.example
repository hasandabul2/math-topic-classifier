# ══════════════════════════════════════════════════════════════════════════
# Math Topic Classifier — Environment Variables
# ══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.

# ── Database ──────────────────────────────────────────────────────────────
# In Docker Compose this is set automatically. For local dev:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/math_classifier_db

# ── Model Endpoint (Production Mode) ─────────────────────────────────────
# Set this to your Hugging Face Space URL for real model predictions.
# Leave empty to run in demo mode with keyword-matching mock predictions.
ENDPOINT_URL=
HF_TOKEN=

# ── URLs (Docker / Cloud) ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
PAYMENT_CALLBACK_URL=http://localhost:8000/api/payment/callback

# ── Google OAuth ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── iyzico Payment ────────────────────────────────────────────────────────
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=sandbox-api.iyzipay.com
